'use client'

import { useRef, useMemo, useState } from 'react'
import { useFrame } from '@react-three/fiber'
import * as THREE from 'three'
// import { useIntro } from '../context/IntroContext' // Отключено для дебага

// Выносим функцию генерации за пределы компонента, чтобы строгий линтер React Compiler
// не ругался на использование Math.random (impure functions) во время рендера/useMemo
const generateParticleData = (count: number) => {
    const pos = new Float32Array(count * 3)
    const rnd = new Float32Array(count * 3)

    for(let i = 0; i < count; i++) {
        // Равномерное распределение по диску (корень квадратный из random)
        const r = Math.sqrt(Math.random()) * 0.9
        const theta = Math.random() * Math.PI * 2

        pos[i * 3 + 0] = Math.cos(theta) * r
        pos[i * 3 + 1] = 0 // Лежат ровно на платформе
        pos[i * 3 + 2] = Math.sin(theta) * r

        rnd[i * 3 + 0] = 0.1 + Math.random() * 0.5 // Индивидуальная скорость
        rnd[i * 3 + 1] = Math.random()             // Смещение по времени (offset)
        rnd[i * 3 + 2] = Math.random()             // Смещение угла вихря
    }

    return { pos, rnd }
}

export function MagicParticles() {
    const materialRef = useRef<THREE.ShaderMaterial>(null)
    // const { entered } = useIntro() // Отключено для дебага

    // Количество частиц (60 000 точек для хорошей плотности и производительности)
    const count = 10000

    // Используем useState (lazy init), чтобы избежать повторных вызовов и предупреждений purity
    const [data] = useState(() => generateParticleData(count))
    const positions = data.pos
    const randoms = data.rnd

    const uniforms = useMemo(() => ({
        uTime: { value: 0 },
        uActive: { value: 1.0 } // Триггер для плавного запуска (сразу 1.0 для дебага)
    }), [])

    useFrame((state, delta) => {
        if (!materialRef.current) return

        const safeDelta = Math.min(delta, 0.05)
        materialRef.current.uniforms.uTime.value += safeDelta * 0.3

        // Дебаг: всегда активны, игнорируем entered
        const targetActive = 1.0
        materialRef.current.uniforms.uActive.value = THREE.MathUtils.lerp(
            materialRef.current.uniforms.uActive.value,
            targetActive,
            safeDelta * 1.5 // Скорость растворения/появления
        )
    })

    return (
        // y = -0.95 (подняли на 0.1 от -1.05, чтобы точно быть выше зеркала Платформы)
        <points position={[0, -0.95, 0]}>
            <bufferGeometry>
                <bufferAttribute
                    attach="attributes-position"
                    args={[positions, 3]}
                />
                <bufferAttribute
                    attach="attributes-aRandom"
                    args={[randoms, 3]}
                />
            </bufferGeometry>
            <shaderMaterial
                ref={materialRef}
                transparent={true}
                depthWrite={false}
                blending={THREE.AdditiveBlending}
                uniforms={uniforms}
                vertexShader={`
                    uniform float uTime;
                    uniform float uActive;
                    attribute vec3 aRandom;
                    varying float vAlpha;

                    void main() {
                        vec3 pos = position;

                        // Локальное время жизни частицы (от 0 до 1, затем цикл)
                        float life = fract(uTime * aRandom.x + aRandom.y);

                        // Эффект активации: 0 - лежат и невидимы, 1 - полная спираль
                        float activeEffect = smoothstep(0.0, 1.0, uActive);

                        // Высота подъема (растет только если uActive > 0)
                        float height = life * 5.0 * activeEffect;

                        // Формирование вихря (спирали)
                        float angle = height * 1.2 + aRandom.z * 6.28;
                        
                        // Сужение спирали кверху
                        float radius = length(pos.xz) * (1.0 - life * 0.4 * activeEffect);

                        // Применяем вращение
                        pos.x = cos(angle) * radius;
                        pos.y += height;
                        pos.z = sin(angle) * radius;

                        vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
                        gl_Position = projectionMatrix * mvPosition;

                        // Дебаг: увеличен размер в 5 раз (было 12.0 и 6.0)
                        gl_PointSize = (60.0 * aRandom.x + 30.0) * (1.0 / -mvPosition.z);

                        // Плавное затухание в начале и в конце жизни
                        float lifeAlpha = smoothstep(0.0, 0.1, life) * smoothstep(1.0, 0.7, life);
                        
                        // Полностью прозрачны до триггера
                        vAlpha = lifeAlpha * activeEffect;
                    }
                `}
                fragmentShader={`
                    varying float vAlpha;

                    void main() {
                        // Рисуем мягкий светящийся круг
                        float d = distance(gl_PointCoord, vec2(0.5));
                        float strength = 0.05 / d - 0.1;
                        strength = clamp(strength, 0.0, 1.0);

                        // Циановый неон
                        vec3 color = vec3(0.0, 0.8, 1.0);
                        gl_FragColor = vec4(color, strength * vAlpha);
                    }
                `}
            />
        </points>
    )
}
